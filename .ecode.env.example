# eCode360 API credentials — LOCAL DEV ONLY
# Copy this file to ".ecode.env" (which is gitignored) and fill in your real
# key/secret. Then enable it for local runs by uncommenting in config.yaml:
#     secrets_file: ".ecode.env"
#
# Do NOT put these values in config.yaml — config.yaml is baked into the Lambda
# deployment zip. On AWS, these are injected as Lambda env vars by Terraform.

ECODE_API_KEY=your-api-key-here
ECODE_API_SECRET=your-api-secret-here
