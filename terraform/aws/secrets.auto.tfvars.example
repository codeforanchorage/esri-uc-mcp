# eCode360 API credentials for Terraform → Lambda env vars.
#
# Copy this file to "secrets.auto.tfvars" (gitignored, auto-loaded by Terraform)
# and fill in the real values, OR export them instead:
#     export TF_VAR_ecode_api_key=...
#     export TF_VAR_ecode_api_secret=...
#
# These are wired into the Lambda environment in main.tf as ECODE_API_KEY /
# ECODE_API_SECRET and read at runtime by plugins/ecode/plugin.py.

ecode_api_key    = "your-api-key-here"
ecode_api_secret = "your-api-secret-here"
